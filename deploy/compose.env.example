# Copy this file to deploy/compose.env, then replace every CHANGE_ME value
# before starting Docker Compose. Do not commit deploy/compose.env.

AGV_HTTP_PORT=8000
AGV_MYSQL_ROOT_PASSWORD=CHANGE_ME_generate_a_unique_root_password
AGV_MYSQL_PASSWORD=CHANGE_ME_generate_a_unique_application_password

# The migration container refuses to run until this is explicitly `yes`.
# For existing data, set it only after creating and verifying a MySQL backup.
AGV_MYSQL_BACKUP_CONFIRMED=no

# Local recovery administrator. A real trial deployment needs a unique
# password of at least 12 characters; remove it from the runtime environment
# after the account is confirmed.
AGV_BOOTSTRAP_ADMIN_USERNAME=agv-recovery-admin
AGV_BOOTSTRAP_ADMIN_PASSWORD=CHANGE_ME_generate_a_unique_12_plus_character_password

# Use true only behind HTTPS. Keep localhost HTTP false for the local example.
AGV_AUTH_COOKIE_SECURE=false
AGV_CORS_ALLOW_ORIGINS=http://localhost:8000,http://127.0.0.1:8000
AGV_FRONTEND_BASE_URL=http://localhost:8000

# Optional Keycloak acceptance profile. Keep OIDC disabled unless the profile
# is started and the local platform administrator is ready to approve links.
AGV_OIDC_ENABLED=false
AGV_OIDC_ISSUER_URL=http://agv-keycloak.localhost:8080/realms/agv
AGV_OIDC_CLIENT_ID=agv-web
# Leave empty for the included public Authorization Code + PKCE client. Set it
# only when an external provider uses a confidential client.
AGV_OIDC_CLIENT_SECRET=
AGV_OIDC_STATE_SECRET=CHANGE_ME_generate_a_long_random_cookie_state_secret
AGV_KEYCLOAK_PORT=8080
AGV_KEYCLOAK_ADMIN_USERNAME=agv-local-admin
AGV_KEYCLOAK_ADMIN_PASSWORD=CHANGE_ME_generate_a_local_keycloak_admin_password
