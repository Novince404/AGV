AGV_APP_TITLE=AGV Dispatch Backend
AGV_ROOT_MESSAGE=AGV dispatch backend is running

# Supported backends: memory / sqlite / mysql
AGV_DATA_BACKEND=memory

# SQLite example
# AGV_DATA_BACKEND=sqlite
# AGV_DATABASE_URL=sqlite:///./agv_dispatch.db

# MySQL example
# AGV_DATA_BACKEND=mysql
# AGV_DATABASE_URL=mysql+pymysql://agv_user:your_password@127.0.0.1:3306/agv_dispatch?charset=utf8mb4

AGV_DATABASE_URL=sqlite:///./agv_dispatch.db
AGV_DATABASE_ECHO=false
AGV_DATABASE_AUTO_CREATE=true
AGV_DATABASE_CONNECT_TIMEOUT_SEC=5
AGV_DATABASE_POOL_PRE_PING=true
AGV_SERVE_FRONTEND_DIST=false
# AGV_FRONTEND_DIST_DIR=../frontend/dist

AGV_CORS_ALLOW_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,http://127.0.0.1:5174
# Runtime profile: demo, development, trial, production, or test.
AGV_APP_ENV=demo

# Demo accounts are enabled only for the demo profile by default. Never enable
# them in a trial or production deployment.
AGV_AUTH_DEMO_USERS_ENABLED=true

# For a new trial/production database, set a one-time recovery administrator.
# Use a unique password of at least 12 characters, start the service once, then
# remove the password from the environment after confirming the account exists.
AGV_BOOTSTRAP_ADMIN_USERNAME=
AGV_BOOTSTRAP_ADMIN_PASSWORD=

# Trial/production deployments should use HTTPS and secure cookies.
AGV_AUTH_COOKIE_SECURE=false
AGV_CSRF_ENABLED=false
AGV_AUTH_SESSION_IDLE_TTL_SEC=28800

# Keep legacy unversioned endpoints until v4.0.0.
AGV_LEGACY_API_ENABLED=true

# Generic OpenID Connect. Keep disabled until all values are configured.
AGV_OIDC_ENABLED=false
AGV_OIDC_ISSUER_URL=http://127.0.0.1:8080/realms/agv
AGV_OIDC_CLIENT_ID=agv-web
# Optional: only required when your identity provider configures AGV as a
# confidential client. The included Keycloak PKCE example leaves this empty.
AGV_OIDC_CLIENT_SECRET=
AGV_OIDC_STATE_SECRET=
AGV_FRONTEND_BASE_URL=http://127.0.0.1:5173

# Deterministic scheduler worker. Keep disabled while validating migration from
# the legacy per-vehicle runtime; Docker's scheduler service enables it.
AGV_SCHEDULER_V3_ENABLED=false
AGV_SCHEDULER_TICK_MS=100
AGV_SCHEDULER_LEASE_TTL_SEC=10
