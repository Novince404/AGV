AGV_APP_TITLE=AGV Dispatch Backend
AGV_ROOT_MESSAGE=AGV dispatch backend is running

# Supported backends: memory / sqlite / mysql
AGV_DATA_BACKEND=memory

# SQLite example
# AGV_DATA_BACKEND=sqlite
# AGV_DATABASE_URL=sqlite:///./agv_dispatch.db

# MySQL example
# AGV_DATA_BACKEND=mysql
# AGV_DATABASE_URL=mysql+pymysql://agv_user:your_password@127.0.0.1:3306/agv_dispatch?charset=utf8mb4

AGV_DATABASE_URL=sqlite:///./agv_dispatch.db
AGV_DATABASE_ECHO=false
AGV_DATABASE_AUTO_CREATE=true
AGV_DATABASE_CONNECT_TIMEOUT_SEC=5
AGV_DATABASE_POOL_PRE_PING=true

AGV_CORS_ALLOW_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,http://127.0.0.1:5174
